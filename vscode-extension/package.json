{
  "name": "vylang",
  "displayName": "vylang — Ngôn ngữ lập trình tiếng Việt",
  "description": "Syntax highlighting for the vylang Vietnamese programming language (.vpl files)",
  "version": "0.1.0",
  "publisher": "vyquocvu",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vyquocvu/vylang"
  },
  "contributes": {
    "languages": [
      {
        "id": "vylang",
        "aliases": ["vylang", "Vietnamese Lang"],
        "extensions": [".vpl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vylang",
        "scopeName": "source.vylang",
        "path": "./syntaxes/vylang.tmLanguage.json"
      }
    ]
  }
}
