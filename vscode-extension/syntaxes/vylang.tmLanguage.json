{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "vylang",
  "scopeName": "source.vylang",
  "fileTypes": ["vpl"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword_control" },
    { "include": "#keyword_declaration" },
    { "include": "#keyword_builtin" },
    { "include": "#boolean" },
    { "include": "#float" },
    { "include": "#integer" },
    { "include": "#function_call" },
    { "include": "#function_definition" },
    { "include": "#operator" },
    { "include": "#punctuation" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.vylang",
      "match": "#.*$"
    },
    "keyword_control": {
      "name": "keyword.control.vylang",
      "match": "\\b(khi|nếu|neu|thì|thi|hết|het|khác_thì|khac_thi|trả_về|tra_ve)\\b"
    },
    "keyword_declaration": {
      "name": "keyword.declaration.vylang",
      "match": "\\b(khai_báo|khai_bao|hàm|ham)\\b"
    },
    "keyword_builtin": {
      "name": "support.function.builtin.vylang",
      "match": "\\bin_ra\\b"
    },
    "boolean": {
      "name": "constant.language.boolean.vylang",
      "match": "\\b(đúng|dung|sai)\\b"
    },
    "float": {
      "name": "constant.numeric.float.vylang",
      "match": "\\b[0-9]+\\.[0-9]+\\b"
    },
    "integer": {
      "name": "constant.numeric.integer.vylang",
      "match": "\\b[0-9]+\\b"
    },
    "function_definition": {
      "comment": "Highlights the function name after 'hàm' keyword",
      "match": "\\b(hàm|ham)\\s+([^\\W\\d][\\w]*)",
      "captures": {
        "1": { "name": "keyword.declaration.vylang" },
        "2": { "name": "entity.name.function.vylang" }
      }
    },
    "function_call": {
      "comment": "Highlights identifiers immediately followed by '('",
      "match": "([^\\W\\d][\\w]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.vylang" }
      }
    },
    "operator": {
      "name": "keyword.operator.vylang",
      "match": "(==|!=|>=|<=|>|<|&&|\\|\\||\\+|-|\\*|/|%|=)"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.brackets.round.vylang",
          "match": "[()]"
        },
        {
          "name": "punctuation.brackets.square.vylang",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.comma.vylang",
          "match": ","
        }
      ]
    },
    "identifier": {
      "name": "variable.other.vylang",
      "match": "[^\\W\\d][\\w]*"
    }
  }
}
